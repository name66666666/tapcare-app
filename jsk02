    ]);

    const [messageInput, setMessageInput] = useState('');
    const [chatMessages, setChatMessages] = useState([
      { sender: 'staff', text: '田中健一様、お世話になっております。本日の訪問報告をタイムラインに掲載しました。ご確認ください。', time: '15:35' },
      { sender: 'family', text: '確認しました！いつも丁寧なご報告ありがとうございます。安心いたしました。', time: '16:00' }
    ]);

    const handleSendMessage = () => {
      if (!messageInput.trim()) return;
      const now = new Date();
      const timeStr = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
      setChatMessages([...chatMessages, { sender: 'family', text: messageInput, time: timeStr }]);
      setMessageInput('');
    };

    return (
      <div className="bg-orange-50 min-h-screen">
        {/* 家族用ヘッダー */}
        <header className="bg-orange-500 text-white p-4 shadow-md flex justify-between items-center sticky top-0 z-10">
          <div className="flex items-center space-x-2">
            <Smile className="w-6 h-6" />
            <h1 className="text-xl font-bold tracking-wider">TapCare - 家族連絡</h1>
          </div>
          <button 
            onClick={() => setCurrentScreen('menu')}
            className="bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition"
          >
            メニューに戻る
          </button>
        </header>

        {/* メインエリア */}
        <div className="max-w-md mx-auto p-4 pb-28">
          {/* 上部固定クイックボタン */}
          <div className="bg-white rounded-2xl p-4 shadow-sm border border-orange-100 mb-6 grid grid-cols-2 gap-3 text-center">
            <button className="flex flex-col items-center justify-center p-3 bg-orange-50 hover:bg-orange-100 text-orange-700 rounded-xl transition font-bold text-sm space-y-1">
              <Phone className="w-5 h-5" />
              <span>緊急・施設電話</span>
            </button>
            <button className="flex flex-col items-center justify-center p-3 bg-amber-50 hover:bg-amber-100 text-amber-700 rounded-xl transition font-bold text-sm space-y-1">
              <Calendar className="w-5 h-5" />
              <span>利用予定表</span>
            </button>
          </div>

          {/* セクションタイトル */}
          <h2 className="font-black text-slate-800 text-lg mb-4 flex items-center space-x-2 pl-1">
            <CheckSquare className="w-5 h-5 text-orange-500" />
            <span>最近のご様子（タイムライン）</span>
          </h2>

          {/* タイムライン */}
          <div className="space-y-4 mb-8">
            {timelineData.map((item) => (
              <div key={item.id} className="bg-white rounded-2xl shadow-sm border border-orange-100 overflow-hidden">
                <div className="p-4 flex items-center space-x-3 border-b border-slate-50 bg-slate-50/50">
                  <div className={`p-2 rounded-xl ${item.bg}`}>
                    {item.icon}
                  </div>
                  <div className="flex-1">
                    <h4 className="font-bold text-slate-800 text-sm leading-snug">{item.title}</h4>
                    <div className="flex justify-between items-center mt-0.5">
                      <span className="text-xs text-slate-400 font-medium">{item.time}</span>
                      <span className="text-xs text-orange-600 font-bold bg-orange-50 px-2 py-0.5 rounded-md">{item.staff}</span>
                    </div>
                  </div>
                </div>
                <div className="p-4">
                  <p className="text-slate-600 text-sm leading-relaxed whitespace-pre-line">{item.content}</p>
                </div>
              </div>
            ))}
          </div>

          {/* チャットセクション */}
          <h2 className="font-black text-slate-800 text-lg mb-4 flex items-center space-x-2 pl-1">
            <MessageSquare className="w-5 h-5 text-orange-500" />
            <span>メッセージ相談</span>
          </h2>

