          <span className="font-black text-xl tracking-wider bg-gradient-to-r from-indigo-400 to-orange-400 bg-clip-text text-transparent">TapCare</span>
        </div>
        
        {/* PC用リンク（見た目用） */}
        <div className="hidden md:flex space-x-6 text-sm font-bold text-slate-400">
          <span className="hover:text-white cursor-pointer transition">プロダクト概要</span>
          <span className="hover:text-white cursor-pointer transition">特徴</span>
          <span className="hover:text-white cursor-pointer transition">料金プラン</span>
