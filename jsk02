  // ==========================================
  // 2. 家族専用画面のコンポーネント
  // ==========================================
  const FamilyScreen = () => {
    const [timelineData, setTimelineData] = useState([
      { id: 1, type: 'care', icon: <Heart className="w-5 h-5 text-white" />, title: '本日のご様子（定期訪問）', time: '本日 15:30', staff: '担当：山下ヘルパー', content: 'お昼ご飯の食欲は旺盛で、完食されました。水分もしっかり摂れています。お薬もカレンダー通り間違いなく服用されましたのでご安心ください。デイサービスのお話を楽しそうにされていました。', bg: 'bg-rose-500' },
      { id: 2, type: 'nurse', icon: <Users className="w-5 h-5 text-white" />, title: 'バイタルチェック', time: '本日 14:15', staff: '担当：佐藤看護師', content: '血圧：128/74、体温：36.4℃。すべて平熱・基準内です。足のむくみも先週より引いており、非常に落ち着いた状態を維持されています。', bg: 'bg-teal-500' },
