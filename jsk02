              <div className="space-y-3">
                {notifications.map((n) => (
                  <div key={n.id} className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex flex-col justify-between relative overflow-hidden">
                    {n.type === 'emergency' && <div className="absolute top-0 left-0 bottom-0 w-1.5 bg-rose-500" />}
                    <div className="flex justify-between items-start mb-2">
                      <div>
                        <span className={`text-xs font-bold px-2 py-0.5 rounded mr-2 ${n.type === 'emergency' ? 'bg-rose-100 text-rose-700' : 'bg-blue-100 text-blue-700'}`}>{n.title}</span>
                        <span className="font-bold text-slate-800 text-sm">{n.user}</span>
                      </div>
                      <span className="text-xs text-slate-400 font-medium">{n.time}</span>
