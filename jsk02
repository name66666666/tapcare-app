              <div className="bg-amber-50 border border-amber-200 p-4 rounded-xl text-amber-800 text-sm flex items-start space-x-3 shadow-sm">
                <Bell className="w-5 h-5 flex-shrink-0 mt-0.5 text-amber-600" />
                <div>
