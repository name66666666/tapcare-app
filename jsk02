            >
              <Bell className="w-4 h-4" />
              <span>自動通知管理</span>
              <span className="absolute -top-1 -right-1 bg-rose-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center border-2 border-white font-bold animate-pulse">2</span>
            </button>
          </div>

          {/* タブ中身：ダッシュボード */}
          {activeTab === 'dashboard' && (
            <div className="space-y-6">
              {/* クイック統計カード */}
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200">
                  <div className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">本日の訪問</div>
                  <div className="text-2xl font-black text-indigo-600">12 件</div>
                </div>
                <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200">
                  <div className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">未読家族連絡</div>
                  <div className="text-2xl font-black text-rose-500">3 件</div>
                </div>
                <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200">
                  <div className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">自動通知稼働</div>
                  <div className="text-2xl font-black text-emerald-500">98 %</div>
                </div>
                <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200">
                  <div className="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">登録家族数</div>
                  <div className="text-2xl font-black text-slate-700">45 世帯</div>
                </div>
              </div>

              {/* 家族リスト */}
              <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div className="p-4 bg-slate-50 border-b border-slate-200 flex justify-between items-center">
                  <h3 className="font-bold text-slate-700 flex items-center space-x-2">
                    <User className="w-5 h-5 text-indigo-600" />
                    <span>担当利用者・家族一覧</span>
                  </h3>
                  <span className="text-xs bg-indigo-100 text-indigo-700 font-bold px-2.5 py-1 rounded-full">全員表示</span>
                </div>
                <div className="divide-y divide-slate-100">
                  {[
                    { name: '田中 ハツ 様', rel: '長男：田中 健一 様', status: '自動送信完了', time: '15:30', color: 'bg-emerald-100 text-emerald-800' },
                    { name: '佐藤 清 様', rel: '長女：佐藤 美紀 様', status: '返信待ち', time: '14:15', color: 'bg-amber-100 text-amber-800' },
                    { name: '鈴木 一郎 様', rel: '妻：鈴木 幸子 様', status: '未送信（確認要）', time: '--:--', color: 'bg-slate-100 text-slate-800' }
