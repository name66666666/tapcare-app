      </nav>

      {/* スマホ用サイドバー（見た目用） */}
      {sidebarOpen && (
        <div className="fixed inset-0 bg-slate-950/95 z-40 p-6 flex flex-col justify-start space-y-6 pt-20 md:hidden">
          <span className="text-lg font-bold text-slate-300 border-b border-slate-800 pb-2">プロダクト概要</span>
          <span className="text-lg font-bold text-slate-300 border-b border-slate-800 pb-2">特徴</span>
          <span className="text-lg font-bold text-slate-300 border-b border-slate-800 pb-2">料金プラン</span>
        </div>
      )}

      {/* メインヒーローセクション */}
      <main className="max-w-4xl mx-auto px-4 py-12 text-center flex-1 flex flex-col justify-center relative z-10">
        <span className="text-xs md:text-sm bg-slate-800 text-indigo-400 border border-indigo-500/30 font-bold px-4 py-1.5 rounded-full inline-block mx-auto mb-4 tracking-widest uppercase">
          家族連絡自動化 SaaS アプリケーション
        </span>
        <h2 className="text-3xl md:text-5xl font-black tracking-tight leading-tight mb-4">
          介護現場の報告を、<br className="md:hidden" />
          <span className="bg-gradient-to-r from-indigo-400 via-purple-400 to-orange-400 bg-clip-text text-transparent">家族の安心に自動翻訳</span>する。
        </h2>
        <p className="text-sm md:text-base text-slate-400 max-w-xl mx-auto mb-10 leading-relaxed font-medium">
          TapCareは、スタッフが残した簡単な業務記録から家族向けのLINE通知を自動生成。業務負担を増やさずに、透明性の高いケアを届けます。
        </p>

        {/* 🚀 メインの画面切り替えスイッチ（体験エリア） */}
        <div className="bg-slate-800/50 border border-slate-700/50 p-6 rounded-3xl max-w-2xl mx-auto w-full shadow-2xl backdrop-blur-sm">
          <h3 className="text-sm font-bold text-slate-300 mb-4 tracking-wider uppercase flex items-center justify-center space-x-2">
            <Clock className="w-4 h-4 text-indigo-400" />
            <span>開発中のプロトタイプ画面を切り替えて体験する</span>
          </h3>
          
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {/* スタッフ画面へ */}
            <button 
              onClick={() => setCurrentScreen('staff')}
              className="group p-5 bg-gradient-to-br from-indigo-600 to-indigo-700 hover:from-indigo-500 hover:to-indigo-600 text-white rounded-2xl shadow-xl shadow-indigo-600/20 text-left transition transform hover:-translate-y-0.5 duration-200"
            >
              <div className="flex justify-between items-start mb-2">
                <div className="p-2.5 bg-white/10 rounded-xl group-hover:scale-110 transition duration-200">
                  <Users className="w-6 h-6" />
                </div>
                <ChevronRight className="w-5 h-5 text-white/50 group-hover:text-white transition" />
              </div>
              <div className="font-black text-lg mb-0.5">スタッフ専用画面 ➔</div>
              <p className="text-xs text-indigo-200 leading-relaxed">利用者の記録入力、自動通知ルールの稼働ログ・アラートを確認できます。</p>
            </button>

            {/* 家族画面へ */}
            <button 
              onClick={() => setCurrentScreen('family')}
              className="group p-5 bg-gradient-to-br from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white rounded-2xl shadow-xl shadow-orange-600/20 text-left transition transform hover:-translate-y-0.5 duration-200"
            >
              <div className="flex justify-between items-start mb-2">
                <div className="p-2.5 bg-white/10 rounded-xl group-hover:scale-110 transition duration-200">
                  <Smile className="w-6 h-6" />
                </div>
                <ChevronRight className="w-5 h-5 text-white/50 group-hover:text-white transition" />
              </div>
              <div className="font-black text-lg mb-0.5">家族専用連絡画面 ➔</div>
              <p className="text-xs text-orange-100 leading-relaxed">LINE等からアクセスする画面。自動翻訳されたタイムラインやチャットを閲覧できます。</p>
            </button>
          </div>
        </div>
      </main>

      {/* フッター */}
      <footer className="p-4 text-center text-xs text-slate-500 font-bold tracking-wider border-t border-slate-800 relative z-10">
        &copy; {new Date().getFullYear()} TapCare Inc. All rights reserved.
      </footer>
    </div>
  );
}
